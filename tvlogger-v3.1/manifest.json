{
  "manifest_version": 3,
  "name": "TradingView Logger",
  "version": "3.1.0",
  "description": "Hisse değişimi, fiyat, inceleme süresi ve kişisel notlarınızı takip edin. Loglar OPFS'te arşivlenir.",
  "permissions": [
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://*.tradingview.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.tradingview.com/*"],
      "js": [
        "src/shared/constants.js",
        "src/shared/utils.js",
        "src/content/detector.js",
        "src/content/timer.js",
        "src/content/toast.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "TradingView Logger"
  },
  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
